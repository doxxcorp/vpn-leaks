<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{{ document_title }}</title>
  <style>{{ report_css }}</style>
</head>
<body>
  <div class="shell">
    <header class="report-header anim-in">
      {% if logo_svg %}
      <div class="logo-wrap" aria-hidden="true">{{ logo_svg }}</div>
      {% endif %}
      <div>
        <h1>{{ document_title }}</h1>
        <p class="report-meta">
          Generated {{ generated_utc }}
          {% if dashboard.markdown_basename %}
          · <a href="{{ dashboard.markdown_basename }}">Markdown export</a>
          {% endif %}
        </p>
      </div>
    </header>

    <section class="risk-strip anim-in anim-delay-1" aria-label="Risk summary">
      {% set sev = dashboard.max_overall_severity %}
      <span class="severity-pill sev-{% if sev == 'CRITICAL' %}critical{% elif sev == 'HIGH' %}high{% elif sev == 'MEDIUM' %}medium{% elif sev == 'LOW' %}low{% else %}info{% endif %}">
        Rollup {{ sev }}
      </span>
      <div class="leak-chips" aria-label="Leak flags across locations">
        <span class="leak-chip {% if dashboard.leak_flags.dns %}on{% else %}off{% endif %}">DNS leak: {{ 'yes' if dashboard.leak_flags.dns else 'no' }}</span>
        <span class="leak-chip {% if dashboard.leak_flags.webrtc %}on{% else %}off{% endif %}">WebRTC leak: {{ 'yes' if dashboard.leak_flags.webrtc else 'no' }}</span>
        <span class="leak-chip {% if dashboard.leak_flags.ipv6 %}on{% else %}off{% endif %}">IPv6 leak: {{ 'yes' if dashboard.leak_flags.ipv6 else 'no' }}</span>
      </div>
      <span style="color:var(--color-muted);font-size:0.85rem;">{{ dashboard.run_count }} location(s)</span>
    </section>

    {% if dashboard.top_findings %}
    <section class="viz-panel anim-in anim-delay-2" aria-labelledby="findings-h">
      <h3 id="findings-h">High / critical findings</h3>
      <ul class="findings-list">
        {% for f in dashboard.top_findings %}
        <li><strong>{{ f.severity }}</strong> — {{ f.title }} <span style="color:var(--color-muted)">({{ f.category }})</span></li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    <section aria-labelledby="loc-h" class="anim-in anim-delay-2">
      <h2 class="section-title" id="loc-h">Benchmark locations</h2>
      <p class="loc-section-hint">Exit IPv4 / IPv6 above are observed tunnel addresses. Tags below are harness leak-test outcomes (not the same as “has IPv6”).</p>
      <div class="loc-grid">
        {% for loc in dashboard.location_cards %}
        <article class="loc-card">
          <h3 class="loc-title" title="{{ loc.location_label }}">{{ loc.location_label_display }}</h3>
          <p class="loc-sub">{{ loc.run_id }} / {{ loc.location_id }}</p>
          <dl class="data-row"><dt>Exit IPv4</dt><dd>{{ loc.exit_ip_v4 or '—' }}</dd></dl>
          <dl class="data-row"><dt>Exit IPv6</dt><dd>{{ loc.exit_ip_v6 or '—' }}</dd></dl>
          <dl class="data-row data-row--asn"><dt>ASN</dt><dd>{% if loc.asn %}{{ loc.asn }}{% if loc.asn_holder %} — {{ loc.asn_holder }}{% endif %}{% else %}—{% endif %}</dd></dl>
          <dl class="data-row"><dt>Mode</dt><dd>{{ loc.connection_mode }}</dd></dl>
          <dl class="data-row data-row--resolvers"><dt>Resolvers</dt><dd>{{ loc.dns_summary }}</dd></dl>
          <div class="flag-row" title="DNS / WebRTC / IPv6 leak flags from this benchmark harness">
            <span class="badge {% if loc.dns_leak == true %}unanswered{% elif loc.dns_leak == false %}answered{% else %}not_testable_dynamically{% endif %}">DNS</span>
            <span class="badge {% if loc.webrtc_leak == true %}unanswered{% elif loc.webrtc_leak == false %}answered{% else %}not_testable_dynamically{% endif %}">WebRTC</span>
            <span class="badge {% if loc.ipv6_leak == true %}unanswered{% elif loc.ipv6_leak == false %}answered{% else %}not_testable_dynamically{% endif %}">IPv6</span>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>

    {% if dashboard.web_exposure.has_any %}
    <section class="tp-panel anim-in anim-delay-3" aria-labelledby="tp-h">
      <h2 class="section-title" id="tp-h">Website and DNS surface</h2>
      <p style="color:var(--color-muted);font-size:0.88rem;margin:0;">HAR-derived hosts and provider DNS from <code>competitor_probe</code> and <code>surface_urls</code> (see <a href="../docs/website-exposure-methodology.md">methodology</a>).</p>
      <p style="margin:0.5rem 0 0;font-size:0.85rem;">Unique hosts: <strong>{{ dashboard.web_exposure.merged_har.merged_unique_hosts | length }}</strong> · Trackers: <strong>{{ dashboard.web_exposure.merged_har.merged_tracker_candidates | length }}</strong> · CDN hints: <strong>{{ dashboard.web_exposure.merged_har.merged_cdn_candidates | length }}</strong></p>
      {% if dashboard.web_exposure.dns_rows %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Provider DNS (apex)</p>
      <div class="web-exposure-table-wrap">
        <table class="web-exposure-table">
          <thead>
            <tr><th>Domain</th><th>NS (sample)</th><th>MX (sample)</th><th>IPv6 apex</th></tr>
          </thead>
          <tbody>
            {% for row in dashboard.web_exposure.dns_rows %}
            <tr>
              <td><code>{{ row.domain }}</code></td>
              <td class="cell-mono">{{ row.ns }}</td>
              <td class="cell-mono">{{ row.mx }}</td>
              <td>{{ row.ipv6_note }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
      {% if dashboard.third_party.apex_domains %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Apex domains probed</p>
      <ul class="mono-list">
        {% for d in dashboard.third_party.apex_domains %}
        <li>{{ d }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if dashboard.third_party.portal_hosts %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Portal hosts</p>
      <ul class="mono-list">
        {% for h in dashboard.third_party.portal_hosts %}
        <li>{{ h }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if dashboard.web_exposure.surface_rows %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Surface URL matrix</p>
      <div class="web-exposure-table-wrap">
        <table class="web-exposure-table">
          <thead>
            <tr><th>page_type</th><th>URL</th><th>status</th></tr>
          </thead>
          <tbody>
            {% for s in dashboard.web_exposure.surface_rows %}
            <tr>
              <td>{{ s.page_type }}</td>
              <td class="cell-mono">{{ s.url }}</td>
              <td>{% if s.error %}error{% else %}{{ s.status | default('—') }}{% endif %}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% endif %}
      {% if dashboard.third_party.surface_urls_sample %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Surface URLs (sample)</p>
      <ul class="mono-list">
        {% for u in dashboard.third_party.surface_urls_sample %}
        <li>{{ u }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if dashboard.third_party.tracker_candidates %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Tracker / analytics candidates (HAR)</p>
      <ul class="mono-list">
        {% for t in dashboard.third_party.tracker_candidates %}
        <li>{{ t }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if dashboard.third_party.cdn_candidates %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">CDN candidates (HAR)</p>
      <ul class="mono-list">
        {% for c in dashboard.third_party.cdn_candidates %}
        <li>{{ c }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if dashboard.third_party.probe_urls_sample %}
      <p style="margin:0.75rem 0 0;font-size:0.85rem;font-weight:600;">Competitor web probe URLs (sample)</p>
      <ul class="mono-list">
        {% for u in dashboard.third_party.probe_urls_sample %}
        <li>{{ u }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </section>
    {% endif %}

    <section class="viz-section anim-in anim-delay-3" id="visualizations" aria-labelledby="viz-heading">
      <h2 class="section-title" id="viz-heading">Coverage and graph</h2>

      <div class="viz-panel">
        <h3>SPEC framework coverage</h3>
        {% if framework_rollup.has_framework %}
        <p class="graph-blurb" style="margin-top:0;">Merged per question ID across locations ({{ framework_rollup.question_bank_count }} in bank). Each ID uses the <strong>strictest</strong> status across benchmark rows: unanswered beats partially answered beats answered. Bar shows share of IDs by status. For some <strong>DYNAMIC_PARTIAL</strong> questions (e.g. <strong>FP-001</strong>), <strong>answered</strong> means the harness captured the intended evidence class in <code>normalized.json</code>—not that the English question is fully settled by desk review; use per-ID summaries, category context, and raw artifacts to interpret.</p>
        {% set c = framework_rollup.coverage_counts %}
        {% set total = (c.answered + c.partially_answered + c.unanswered + c.not_testable_dynamically) %}
        {% if total > 0 %}
        <div class="stacked-bar" role="img" aria-label="Framework question coverage stacked by status">
          <span class="seg answered" style="width: {{ (100 * c.answered / total) }}%"></span>
          <span class="seg partially_answered" style="width: {{ (100 * c.partially_answered / total) }}%"></span>
          <span class="seg unanswered" style="width: {{ (100 * c.unanswered / total) }}%"></span>
          <span class="seg not_testable_dynamically" style="width: {{ (100 * c.not_testable_dynamically / total) }}%"></span>
        </div>
        <div class="legend">
          <span><i class="dot" style="background:var(--color-answered)"></i> answered {{ c.answered }}</span>
          <span><i class="dot" style="background:var(--color-partial)"></i> partial {{ c.partially_answered }}</span>
          <span><i class="dot" style="background:var(--color-unanswered)"></i> unanswered {{ c.unanswered }}</span>
          <span><i class="dot" style="background:var(--color-nottest)"></i> N/A dynamic {{ c.not_testable_dynamically }}</span>
        </div>
        {% else %}
        <p class="graph-blurb">No coverage entries found.</p>
        {% endif %}
        {% else %}
        <p class="graph-blurb">No <code>framework</code> block on normalized runs. Re-run without <code>--no-framework</code>.</p>
        {% endif %}
      </div>

      <div class="viz-panel">
        <h3>Exposure graph</h3>
        <p class="graph-blurb">Same data as <code>vpn-leaks graph-export --provider {{ vpn_slug }}</code>. <strong>How to read:</strong> the VPN node links to your observed <strong>exit IPv4</strong>, then to its <strong>ASN</strong>; to <strong>policy URLs</strong> when policies were fetched; and (when competitor DNS ran) to <strong>provider apex domains</strong> → <strong>nameservers</strong> → <strong>glue IPs</strong> → <strong>ASN</strong>. Drag to rotate, scroll to zoom. Node labels show on load.</p>
        <div id="graph-err" hidden></div>
        <div id="exposure-graph" role="application" aria-label="Exposure graph 3D visualization"></div>
      </div>
    </section>

    {% if dashboard.has_framework and dashboard.spec_by_category %}
    <section class="spec-zone anim-in anim-delay-4" aria-labelledby="spec-h">
      <h2 class="section-title" id="spec-h">SPEC questions by category</h2>
      {% if dashboard.run_count > 1 %}
      <p class="spec-merge-hint">Merged answers use the strictest status per question ID across all {{ dashboard.run_count }} locations. If one location lacks evidence for a question, the merged row can stay open even when another location looks fine—open each question or use the markdown “Detailed runs” section for per-location coverage.</p>
      {% endif %}
      {% for cat in dashboard.spec_by_category %}
      <details class="spec-cat">
        <summary class="spec-cat-summary">
          <span class="spec-cat-leading">
            <img class="spec-cat-icon" src="{{ cat.icon_href }}" width="24" height="24" alt="" decoding="async" loading="lazy"/>
            <span class="spec-cat-title">{{ cat.category_label }}</span>
          </span>
          <span class="spec-cat-count" aria-label="{{ cat.questions | length }} questions in this category">{{ cat.questions | length }}</span>
        </summary>
        <div class="spec-questions">
          {% for q in cat.questions %}
          <details class="spec-q">
            <summary class="spec-q-summary">
              <span class="spec-q-top">
                <span class="spec-q-id"><code>{{ q.question_id }}</code></span>
                <span class="badge {{ q.answer_status }}">{{ q.answer_status | replace('_', ' ') }}</span>
              </span>
              <span class="spec-q-preview">{{ q.list_preview }}</span>
            </summary>
            <div class="spec-q-body">
              <dl class="spec-q-dl">
                <dt>Question</dt>
                <dd>{{ q.question_text or '—' }}</dd>
                <dt>Status</dt>
                <dd><span class="badge {{ q.answer_status }}">{{ q.answer_status | replace('_', ' ') }}</span></dd>
                <dt>Summary</dt>
                <dd>{{ q.answer_summary or '—' }}</dd>
                {% if q.notes %}
                <dt>Notes</dt>
                <dd>{{ q.notes }}</dd>
                {% endif %}
                {% if q.next_steps and q.next_steps != '—' %}
                <dt>Next steps</dt>
                <dd>{{ q.next_steps }}</dd>
                {% endif %}
              </dl>
            </div>
          </details>
          {% endfor %}
        </div>
      </details>
      {% endfor %}
    </section>
    {% endif %}

    <details class="report-appendix anim-in anim-delay-4">
      <summary>Full narrative export (markdown-derived)</summary>
      <article class="report-body">
        {{ report_html }}
      </article>
    </details>
  </div>

  <script type="application/json" id="vpn-leaks-exposure-graph">{{ exposure_graph_json|safe }}</script>
  <script type="module">
    import ForceGraph3D from "https://esm.sh/3d-force-graph@1.73.3?deps=three@0.160.0";
    import SpriteText from "https://esm.sh/three-spritetext@1.9.4?deps=three@0.160.0";

    const errEl = document.getElementById("graph-err");
    const mount = document.getElementById("exposure-graph");

    function showErr(msg) {
      errEl.hidden = false;
      errEl.textContent = msg;
    }

    function nodeCaption(n) {
      const typ = n.type || "?";
      const raw = String(n.label || n.id || "");
      const snip = raw.length > 42 ? `${raw.slice(0, 40)}…` : raw;
      return `[${typ}] ${snip}`;
    }

    const rawEl = document.getElementById("vpn-leaks-exposure-graph");
    let data;
    try {
      data = JSON.parse(rawEl.textContent);
    } catch (e) {
      showErr("Failed to parse embedded exposure graph JSON — " + e);
      throw e;
    }

    const nodes = data.nodes || [];
    const links = (data.edges || []).map((e) => ({
      source: e.source,
      target: e.target,
      relation: e.relation,
    }));

    if (nodes.length === 0) {
      showErr("No graph nodes for this provider (empty exposure graph).");
    } else {
      const fg = ForceGraph3D()(mount)
        .width(mount.clientWidth)
        .height(mount.clientHeight)
        .nodeLabel((n) => `[${n.type}] ${n.label || n.id}`)
        .nodeAutoColorBy("type")
        .nodeThreeObjectExtend(true)
        .nodeThreeObject((n) => {
          const s = new SpriteText(nodeCaption(n));
          s.color = "rgba(210, 218, 228, 0.92)";
          s.textHeight = 3.2;
          s.position.set(0, -14, 0);
          return s;
        })
        .linkDirectionalParticles(0);

      fg.graphData({ nodes, links });

      const resize = () => {
        fg.width(mount.clientWidth).height(mount.clientHeight);
      };
      const ro = new ResizeObserver(resize);
      ro.observe(mount);
    }
  </script>
</body>
</html>
