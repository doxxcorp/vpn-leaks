# Copy to .github/workflows/ci.yml when you have GitHub OAuth `workflow` scope
# or use SSH with a key that can push workflow files.
name: CI

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Install
        run: |
          pip install -e ".[dev]"
      - name: Ruff
        run: ruff check vpn_leaks tests
      - name: Pytest
        run: pytest tests -q
