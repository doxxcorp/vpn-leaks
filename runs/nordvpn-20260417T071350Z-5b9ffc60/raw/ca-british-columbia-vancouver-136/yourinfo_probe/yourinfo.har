      {
        "pageref": "page@80c32a8da8e160c2d5dac87194e1d79e",
        "startedDateTime": "2026-04-17T07:14:53.475Z",
        "time": 159.964,
        "request": {
          "method": "GET",
          "url": "https://yourinfo.ai/js/fingerprint.js",
          "httpVersion": "HTTP/2.0",
          "cookies": [],
          "headers": [
            { "name": ":authority", "value": "yourinfo.ai" },
            { "name": ":method", "value": "GET" },
            { "name": ":path", "value": "/js/fingerprint.js" },
            { "name": ":scheme", "value": "https" },
            { "name": "accept", "value": "*/*" },
            { "name": "accept-encoding", "value": "gzip, deflate, br, zstd" },
            { "name": "priority", "value": "u=1" },
            { "name": "referer", "value": "https://yourinfo.ai/" },
            { "name": "sec-ch-ua", "value": "\"Not:A-Brand\";v=\"99\", \"HeadlessChrome\";v=\"145\", \"Chromium\";v=\"145\"" },
            { "name": "sec-ch-ua-mobile", "value": "?0" },
            { "name": "sec-ch-ua-platform", "value": "\"macOS\"" },
