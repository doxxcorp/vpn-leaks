        },
        "response": {
          "status": 200,
          "statusText": "",
          "httpVersion": "HTTP/2.0",
          "cookies": [],
          "headers": [
            { "name": "accept-ranges", "value": "bytes" },
            { "name": "content-length", "value": "40662" },
            { "name": "content-type", "value": "text/javascript; charset=utf-8" },
            { "name": "date", "value": "Fri, 17 Apr 2026 07:14:53 GMT" },
            { "name": "last-modified", "value": "Fri, 23 Jan 2026 17:24:06 GMT" }
          ],
          "content": {
            "size": 40662,
            "mimeType": "text/javascript; charset=utf-8",
            "compression": 0,
            "text": "/**\n * YourInfo.ai - Browser Fingerprinting Module\n * Collects device/browser characteristics for identification\n */\n\nconst Fingerprint = {\n    /**\n     * Collect all fingerprint data\n     */\n    async collect() {\n        const [\n            screen,\n            hardware,\n            webgl,\n            canvas,\n            audio,\n            fonts,\n            browser,\n            network,\n            battery,\n            media,\n            storage,\n            webrtc,\n            extensions,\n            crypto,\n            topics,\n            natType\n        ] = await Promise.all([\n            this.getScreenInfo(),\n            this.getHardwareInfo(),\n            this.getWebGLInfo(),\n            this.getCanvasFingerprint(),\n            this.getAudioFingerprint(),\n            this.detectFonts(),\n            this.getBrowserInfo(),\n            this.getNetworkInfo(),\n            this.getBatteryInfo(),\n            this.getMediaDevices(),\n            this.getStorageInfo(),\n            this.getWebRTCIPs(),\n            this.detectExtensions(),\n            this.detectCryptoWallets(),\n            this.getChromeTopics(),\n            this.detectNATType()\n        ]);\n\n        const data = {\n            // Screen\n            screen_width: screen.width,\n            screen_height: screen.height,\n            screen_color_depth: screen.colorDepth,\n            device_pixel_ratio: screen.pixelRatio,\n            screen_orientation: screen.orientation,\n            window_width: window.innerWidth,\n            window_height: window.innerHeight,\n\n            // Hardware\n            hardware_concurrency: hardware.cores,\n            device_memory: hardware.memory,\n            max_touch_points: hardware.touchPoints,\n\n            // Platform\n            platform: navigator.platform,\n            language: navigator.language,\n            languages: [...navigator.languages],\n            timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,\n            timezone_offset: new Date().getTimezoneOffset(),\n\n            // WebGL\n            webgl_vendor: webgl.vendor,\n            webgl_renderer: webgl.renderer,\n            webgl_version: webgl.version,\n            webgl_extensions: webgl.extensionCount,\n\n            // Fingerprint hashes\n            canvas_hash: canvas,\n            audio_hash: audio,\n            webgl_hash: webgl.hash,\n\n            // Fonts\n            fonts_detected: fonts,\n            font_count: fonts.length,\n\n            // Browser\n            user_agent: navigator.userAgent,\n            browser_name: browser.name,\n            browser_version: browser.version,\n            cookies_enabled: navigator.cookieEnabled,\n            local_storage: this.hasLocalStorage(),\n            session_storage: this.hasSessionStorage(),\n            indexed_db: this.hasIndexedDB(),\n            do_not_track: navigator.doNotTrack === '1',\n            global_privacy_control: navigator.globalPrivacyControl ?? null,\n            ad_blocker_detected: await this.detectAdBlocker(),\n\n            // Network\n            connection_type: network.type,\n            connection_downlink: network.downlink,\n            connection_rtt: network.rtt,\n\n            // Battery\n            battery_level: battery.level,\n            battery_charging: battery.charging,\n\n            // Media\n            audio_inputs: media.audioinput,\n            video_inputs: media.videoinput,\n            audio_outputs: media.audiooutput,\n\n            // Storage quota\n            storage_quota: storage.quota,\n            storage_usage: storage.usage,\n\n            // WebRTC\n            webrtc_local_ips: webrtc,\n\n            // Extensions\n            extensions_detected: extensions,\n\n            // Crypto wallets\n            crypto_wallets: crypto,\n\n            // Chrome Topics API\n            chrome_topics: topics,\n\n            // Bot detection\n            is_automated: this.isAutomated(),\n            is_headless: this.isHeadless(),\n            \n            // NAT Type detection\n            nat_type: natType.type,\n            nat_details: natType.details,\n            nat_local_ips: natType.local_ips,\n            nat_public_ips: natType.public_ips,\n        };\n\n        // Generate fingerprint ID\n        data.fingerprint_id = await this.generateFingerprintID(data);\n        data.confidence = this.calculateConfidence(data);\n\n        return data;\n    },\n\n    // Screen info\n    getScreenInfo() {\n        return {\n            width: screen.width,\n            height: screen.height,\n            colorDepth: screen.colorDepth,\n            pixelRatio: window.devicePixelRatio,\n            orientation: screen.orientation?.type || null\n        };\n    },\n\n    // Hardware info\n    getHardwareInfo() {\n        return {\n            cores: navigator.hardwareConcurrency || 0,\n            memory: navigator.deviceMemory || null,\n            touchPoints: navigator.maxTouchPoints || 0\n        };\n    },\n\n    // WebGL info (reveals GPU)\n    getWebGLInfo() {\n        try {\n            const canvas = document.createElement('canvas');\n            const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');\n            if (!gl) return { vendor: null, renderer: null, version: null, extensionCount: 0, hash: null };\n\n            const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');\n            const extensions = gl.getSupportedExtensions() || [];\n\n            const params = [\n                gl.getParameter(gl.VERSION),\n                gl.getParameter(gl.SHADING_LANGUAGE_VERSION),\n                gl.getParameter(gl.MAX_TEXTURE_SIZE),\n                extensions.length\n            ].join('|');\n\n            return {\n                vendor: debugInfo ? gl.getParameter(debugInfo.UNMASKED_VENDOR_WEBGL) : null,\n                renderer: debugInfo ? gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) : null,\n                version: gl.getParameter(gl.VERSION),\n                extensionCount: extensions.length,\n                hash: this.hash(params)\n            };\n        } catch {\n            return { vendor: null, renderer: null, version: null, extensionCount: 0, hash: null };\n        }\n    },\n\n    // Canvas fingerprint\n    getCanvasFingerprint() {\n        try {\n            const canvas = document.createElement('canvas');\n            canvas.width = 200;\n            canvas.height = 50;\n            const ctx = canvas.getContext('2d');\n            if (!ctx) return null;\n\n            ctx.textBaseline = 'top';\n            ctx.font = \"14px 'Arial'\";\n            ctx.fillStyle = '#f60';\n            ctx.fillRect(125, 1, 62, 20);\n            ctx.fillStyle = '#069';\n            ctx.fillText('YourInfo.ai fp', 2, 15);\n            ctx.fillStyle = 'rgba(102, 204, 0, 0.7)';\n            ctx.fillText('YourInfo.ai fp', 4, 17);\n            \n            ctx.beginPath();\n            ctx.arc(50, 25, 20, 0, Math.PI * 2, true);\n            ctx.closePath();\n            ctx.fill();\n\n            return this.hash(canvas.toDataURL());\n        } catch {\n            return null;\n        }\n    },\n\n    // Audio fingerprint\n    async getAudioFingerprint() {\n        try {\n            const AudioContext = window.AudioContext || window.webkitAudioContext;\n            if (!AudioContext) return null;\n\n            const ctx = new AudioContext();\n            const oscillator = ctx.createOscillator();\n            const analyser = ctx.createAnalyser();\n            const gain = ctx.createGain();\n            const compressor = ctx.createDynamicsCompressor();\n\n            oscillator.type = 'triangle';\n            oscillator.frequency.setValueAtTime(10000, ctx.currentTime);\n            gain.gain.setValueAtTime(0, ctx.currentTime);\n\n            oscillator.connect(compressor);\n            compressor.connect(analyser);\n            analyser.connect(gain);\n            gain.connect(ctx.destination);\n\n            oscillator.start(0);\n            await new Promise(r => setTimeout(r, 100));\n\n            const data = new Float32Array(analyser.frequencyBinCount);\n            analyser.getFloatFrequencyData(data);\n\n            oscillator.stop();\n            await ctx.close();\n\n            return this.hash(data.slice(0, 30).join(','));\n        } catch {\n            return null;\n        }\n    },\n\n    // Font detection - includes profession-indicating fonts\n    detectFonts() {\n        const testFonts = [\n            // Common system fonts\n            'Arial', 'Arial Black', 'Comic Sans MS', 'Courier New', 'Georgia',\n            'Impact', 'Lucida Console', 'Palatino Linotype', 'Tahoma',\n            'Times New Roman', 'Trebuchet MS', 'Verdana', 'Helvetica',\n            \n            // Developer fonts (IMPORTANT - reveals programmers!)\n            'Monaco', 'Menlo', 'Consolas', 'Fira Code', 'JetBrains Mono',\n            'Source Code Pro', 'Cascadia Code', 'Cascadia Mono', 'Hack',\n            'Inconsolata', 'Anonymous Pro', 'Ubuntu Mono', 'Roboto Mono',\n            'IBM Plex Mono', 'Victor Mono', 'Iosevka', 'Dank Mono',\n            'Operator Mono', 'Fantasque Sans Mono', 'Input Mono',\n            \n            // Apple fonts (macOS/iOS users)\n            'SF Pro', 'SF Pro Display', 'SF Pro Text', 'SF Mono', 'SF Compact',\n            'Helvetica Neue', 'Lucida Grande', 'Apple Chancery', 'Optima',\n            \n            // Designer fonts (IMPORTANT - reveals designers!)\n            'Helvetica Neue', 'Futura', 'Avenir', 'Avenir Next', 'Gotham',\n            'Proxima Nova', 'Brandon Grotesque', 'Museo Sans', 'Montserrat',\n            'Raleway', 'Lato', 'Nunito', 'Poppins', 'Inter', 'Work Sans',\n            'Playfair Display', 'Merriweather', 'Libre Baskerville',\n            \n            // Adobe fonts (creative professionals!)\n            'Adobe Garamond Pro', 'Adobe Caslon Pro', 'Minion Pro', 'Myriad Pro',\n            'Adobe Clean', 'Acumin Pro', 'Source Sans Pro', 'Source Serif Pro',\n            \n            // Microsoft Office fonts\n            'Calibri', 'Cambria', 'Candara', 'Constantia', 'Corbel',\n            'Segoe UI', 'Segoe UI Semibold', 'Bahnschrift',\n            \n            // Google fonts\n            'Roboto', 'Open Sans', 'Noto Sans', 'Noto Serif', 'Oswald',\n            'Droid Sans', 'Droid Serif', 'Material Icons',\n            \n            // Linux fonts\n            'Liberation Sans', 'Liberation Mono', 'Liberation Serif',\n            'DejaVu Sans', 'DejaVu Serif', 'DejaVu Sans Mono',\n            'FreeSans', 'FreeSerif', 'FreeMono',\n            \n            // Foreign language fonts (reveals language background!)\n            'SimSun', 'SimHei', 'Microsoft YaHei', 'PingFang SC', 'Hiragino Sans', // Chinese\n            'MS Gothic', 'MS Mincho', 'Yu Gothic', 'Hiragino Kaku Gothic', // Japanese\n            'Malgun Gothic', 'Batang', 'Gulim', // Korean\n            'Arial Hebrew', 'Times New Roman Hebrew', // Hebrew\n            'Arial Arabic', 'Tahoma Arabic', 'Sakkal Majalla', // Arabic\n            'Mangal', 'Nirmala UI', 'Latha', // Indian languages\n            'Times New Roman Cyrillic', 'Arial Cyrillic', // Russian/Cyrillic\n            \n            // Trading/Finance (reveals traders!)\n            'Bloomberg Terminal', 'Consolas', 'Lucida Console'\n        ];\n\n        const detected = [];\n        const baseFonts = ['monospace', 'sans-serif', 'serif'];\n        const testString = 'mmmmmmmmmmlli';\n        const testSize = '72px';\n\n        const canvas = document.createElement('canvas');\n        const ctx = canvas.getContext('2d');\n        if (!ctx) return detected;\n\n        const baseMeasurements = {};\n        for (const font of baseFonts) {\n            ctx.font = `${testSize} ${font}`;\n            baseMeasurements[font] = ctx.measureText(testString).width;\n        }\n\n        for (const font of testFonts) {\n            for (const base of baseFonts) {\n                ctx.font = `${testSize} '${font}', ${base}`;\n                if (ctx.measureText(testString).width !== baseMeasurements[base]) {\n                    detected.push(font);\n                    break;\n                }\n            }\n        }\n\n        return detected;\n    },\n\n    // Browser info\n    getBrowserInfo() {\n        const ua = navigator.userAgent;\n        let name = 'Unknown';\n        let version = '';\n\n        if (ua.includes('Firefox/')) {\n            name = 'Firefox';\n            version = ua.match(/Firefox\\/(\\d+\\.?\\d*)/)?.[1] || '';\n        } else if (ua.includes('Edg/')) {\n            name = 'Edge';\n            version = ua.match(/Edg\\/(\\d+\\.?\\d*)/)?.[1] || '';\n        } else if (ua.includes('Chrome/')) {\n            name = 'Chrome';\n            version = ua.match(/Chrome\\/(\\d+\\.?\\d*)/)?.[1] || '';\n        } else if (ua.includes('Safari/') && !ua.includes('Chrome')) {\n            name = 'Safari';\n            version = ua.match(/Version\\/(\\d+\\.?\\d*)/)?.[1] || '';\n        }\n\n        return { name, version };\n    },\n\n    // Network info\n    getNetworkInfo() {\n        const conn = navigator.connection;\n        if (!conn) return { type: null, downlink: null, rtt: null };\n        return {\n            type: conn.effectiveType || null,\n            downlink: conn.downlink || null,\n            rtt: conn.rtt || null\n        };\n    },\n\n    // Battery info\n    async getBatteryInfo() {\n        try {\n            if (!navigator.getBattery) return { level: null, charging: null };\n            const battery = await navigator.getBattery();\n            return {\n                level: Math.round(battery.level * 100),\n                charging: battery.charging\n            };\n        } catch {\n            return { level: null, charging: null };\n        }\n    },\n\n    // Media devices\n    async getMediaDevices() {\n        try {\n            if (!navigator.mediaDevices?.enumerateDevices) return { audioinput: 0, videoinput: 0, audiooutput: 0 };\n            const devices = await navigator.mediaDevices.enumerateDevices();\n            const counts = { audioinput: 0, videoinput: 0, audiooutput: 0 };\n            for (const d of devices) {\n                if (d.kind in counts) counts[d.kind]++;\n            }\n            return counts;\n        } catch {\n            return { audioinput: 0, videoinput: 0, audiooutput: 0 };\n        }\n    },\n\n    // Storage info\n    async getStorageInfo() {\n        try {\n            if (!navigator.storage?.estimate) return { quota: null, usage: null };\n            const est = await navigator.storage.estimate();\n            return { quota: est.quota || null, usage: est.usage || null };\n        } catch {\n            return { quota: null, usage: null };\n        }\n    },\n\n    // WebRTC local IPs\n    async getWebRTCIPs() {\n        if (!window.RTCPeerConnection) return [];\n        \n        try {\n            const ips = [];\n            const pc = new RTCPeerConnection({ iceServers: [{ urls: 'stun:stun.l.google.com:19302' }] });\n            pc.createDataChannel('');\n            \n            const offer = await pc.createOffer();\n            await pc.setLocalDescription(offer);\n\n            await new Promise(resolve => {\n                const timeout = setTimeout(resolve, 2000);\n                pc.onicecandidate = (e) => {\n                    if (!e.candidate) { clearTimeout(timeout); resolve(); return; }\n                    const match = e.candidate.candidate.match(/(\\d{1,3}\\.){3}\\d{1,3}/);\n                    if (match && !ips.includes(match[0])) {\n                        if (match[0].startsWith('10.') || match[0].startsWith('192.168.') || match[0].startsWith('172.')) {\n                            ips.push(match[0]);\n                        }\n                    }\n                };\n            });\n\n            pc.close();\n            return ips;\n        } catch {\n            return [];\n        }\n    },\n    \n    /**\n     * Detect NAT type using STUN servers\n     * Returns: { type, local_ips, public_ip, public_port, details }\n     * Types: 'Open', 'Full Cone', 'Restricted Cone', 'Port Restricted', 'Symmetric', 'UDP Blocked', 'Unknown'\n     */\n    async detectNATType() {\n        if (!window.RTCPeerConnection) {\n            return { type: 'Unknown', error: 'WebRTC not supported' };\n        }\n        \n        const stunServers = [\n            'stun:stun.l.google.com:19302',\n            'stun:stun1.l.google.com:19302',\n            'stun:stun2.l.google.com:19302',\n            'stun:stun.cloudflare.com:3478'\n        ];\n        \n        const result = {\n            type: 'Unknown',\n            local_ips: [],\n            public_ips: [],\n            reflexive_candidates: [],\n            host_candidates: [],\n            relay_candidates: [],\n            details: {}\n        };\n        \n        try {\n            // Gather ICE candidates from multiple STUN servers\n            const candidates = await this.gatherICECandidates(stunServers, 5000);\n            \n            // Parse candidates\n            for (const candidate of candidates) {\n                const parsed = this.parseICECandidate(candidate);\n                if (!parsed) continue;\n                \n                if (parsed.type === 'host') {\n                    result.host_candidates.push(parsed);\n                    if (!result.local_ips.includes(parsed.ip)) {\n                        result.local_ips.push(parsed.ip);\n                    }\n                } else if (parsed.type === 'srflx') {\n                    result.reflexive_candidates.push(parsed);\n                    if (!result.public_ips.includes(parsed.ip)) {\n                        result.public_ips.push(parsed.ip);\n                    }\n                } else if (parsed.type === 'relay') {\n                    result.relay_candidates.push(parsed);\n                }\n            }\n            \n            // Determine NAT type based on candidates\n            result.type = this.analyzeNATType(result);\n            result.details = {\n                host_count: result.host_candidates.length,\n                srflx_count: result.reflexive_candidates.length,\n                relay_count: result.relay_candidates.length,\n                unique_public_ips: result.public_ips.length,\n                unique_local_ips: result.local_ips.length\n            };\n            \n            // Check for port mapping consistency (key for NAT type detection)\n            if (result.reflexive_candidates.length >= 2) {\n                const ports = result.reflexive_candidates.map(c => c.port);\n                const uniquePorts = [...new Set(ports)];\n                result.details.port_consistency = uniquePorts.length === 1;\n                result.details.observed_ports = uniquePorts;\n            }\n            \n        } catch (e) {\n            result.error = e.message;\n        }\n        \n        return result;\n    },\n    \n    /**\n     * Gather ICE candidates using multiple STUN servers\n     */\n    async gatherICECandidates(stunServers, timeout) {\n        const candidates = [];\n        \n        const pc = new RTCPeerConnection({ \n            iceServers: stunServers.map(url => ({ urls: url }))\n        });\n        \n        pc.createDataChannel('nat-detection');\n        \n        const offer = await pc.createOffer();\n        await pc.setLocalDescription(offer);\n        \n        await new Promise(resolve => {\n            const timer = setTimeout(resolve, timeout);\n            \n            pc.onicecandidate = (e) => {\n                if (!e.candidate) {\n                    clearTimeout(timer);\n                    resolve();\n                    return;\n                }\n                candidates.push(e.candidate.candidate);\n            };\n        });\n        \n        pc.close();\n        return candidates;\n    },\n    \n    /**\n     * Parse ICE candidate string into structured object\n     */\n    parseICECandidate(candidateStr) {\n        // Example: candidate:842163049 1 udp 1677729535 73.15.210.145 52637 typ srflx raddr 192.168.1.100 rport 52637 generation 0\n        const parts = candidateStr.split(' ');\n        if (parts.length < 8) return null;\n        \n        const result = {\n            foundation: parts[0].split(':')[1],\n            component: parseInt(parts[1]),\n            protocol: parts[2],\n            priority: parseInt(parts[3]),\n            ip: parts[4],\n            port: parseInt(parts[5]),\n            type: null\n        };\n        \n        // Find type\n        const typIdx = parts.indexOf('typ');\n        if (typIdx !== -1 && parts[typIdx + 1]) {\n            result.type = parts[typIdx + 1];\n        }\n        \n        // Find raddr/rport for reflexive candidates\n        const raddrIdx = parts.indexOf('raddr');\n        if (raddrIdx !== -1 && parts[raddrIdx + 1]) {\n            result.relatedAddress = parts[raddrIdx + 1];\n        }\n        \n        const rportIdx = parts.indexOf('rport');\n        if (rportIdx !== -1 && parts[rportIdx + 1]) {\n            result.relatedPort = parseInt(parts[rportIdx + 1]);\n        }\n        \n        return result;\n    },\n    \n    /**\n     * Analyze candidates to determine NAT type\n     */\n    analyzeNATType(result) {\n        const { host_candidates, reflexive_candidates, local_ips, public_ips } = result;\n        \n        // No host candidates = UDP likely blocked\n        if (host_candidates.length === 0) {\n            return 'UDP Blocked';\n        }\n        \n        // No reflexive candidates but have host = UDP blocked or behind strict firewall\n        if (reflexive_candidates.length === 0) {\n            return 'UDP Filtered';\n        }\n        \n        // Check if any local IP matches public IP (no NAT)\n        for (const localIP of local_ips) {\n            if (public_ips.includes(localIP)) {\n                return 'Open (No NAT)';\n            }\n        }\n        \n        // Have reflexive candidates - determine NAT type\n        if (reflexive_candidates.length >= 2) {\n            // Check if same external port is used for different STUN servers\n            const ports = reflexive_candidates.map(c => c.port);\n            const uniquePorts = [...new Set(ports)];\n            \n            if (uniquePorts.length === 1) {\n                // Same port for all - Cone NAT (Full, Restricted, or Port-Restricted)\n                // Can't distinguish between these without a TURN server with special testing\n                return 'Cone NAT';\n            } else {\n                // Different ports - Symmetric NAT\n                return 'Symmetric NAT';\n            }\n        }\n        \n        // Only one reflexive candidate - can't determine cone vs symmetric\n        if (reflexive_candidates.length === 1) {\n            // Check if local and public ports match\n            const srflx = reflexive_candidates[0];\n            if (srflx.relatedPort === srflx.port) {\n                return 'Full Cone NAT';\n            }\n            return 'NAT Detected';\n        }\n        \n        return 'Unknown';\n    },\n\n    // Extension detection\n    async detectExtensions() {\n        const detected = [];\n        const checks = [\n            { name: 'React DevTools', check: () => !!window.__REACT_DEVTOOLS_GLOBAL_HOOK__ },\n            { name: 'Vue DevTools', check: () => !!window.__VUE_DEVTOOLS_GLOBAL_HOOK__ },\n            { name: 'Redux DevTools', check: () => !!window.__REDUX_DEVTOOLS_EXTENSION__ },\n            { name: 'Grammarly', check: () => !!document.querySelector('[data-grammarly-shadow-root]') },\n            { name: 'LastPass', check: () => !!document.querySelector('[data-lastpass-root]') },\n            { name: '1Password', check: () => !!document.querySelector('[data-onepassword-extension]') },\n        ];\n\n        for (const { name, check } of checks) {\n            try { if (check()) detected.push(name); } catch {}\n        }\n\n        return detected;\n    },\n\n    // Crypto wallet detection\n    detectCryptoWallets() {\n        const wallets = [];\n        if (window.ethereum?.isMetaMask) wallets.push('MetaMask');\n        if (window.ethereum?.isCoinbaseWallet) wallets.push('Coinbase Wallet');\n        if (window.ethereum?.isBraveWallet) wallets.push('Brave Wallet');\n        if (window.solana?.isPhantom || window.phantom?.solana) wallets.push('Phantom');\n        if (window.ethereum && !wallets.length) wallets.push('Unknown Web3 Wallet');\n        return wallets;\n    },\n\n    // Chrome Topics API\n    async getChromeTopics() {\n        try {\n            if (!('browsingTopics' in document)) return [];\n            const topics = await document.browsingTopics();\n            return topics.map(t => ({\n                topic_id: t.topic,\n                taxonomy_version: t.taxonomyVersion,\n                model_version: t.modelVersion\n            }));\n        } catch {\n            return [];\n        }\n    },\n\n    // Ad blocker detection\n    async detectAdBlocker() {\n        try {\n            const bait = document.createElement('div');\n            bait.className = 'ad ads adsbox ad-placement';\n            bait.style.cssText = 'position:absolute;top:-10px;left:-10px;width:1px;height:1px;';\n            bait.innerHTML = '&nbsp;';\n            document.body.appendChild(bait);\n            \n            await new Promise(r => setTimeout(r, 100));\n            \n            const blocked = bait.offsetHeight === 0 || bait.offsetWidth === 0 ||\n                getComputedStyle(bait).display === 'none';\n            \n            document.body.removeChild(bait);\n            return blocked;\n        } catch {\n            return null;\n        }\n    },\n\n    // Bot detection\n    isAutomated() {\n        return !!(navigator.webdriver || window.__nightmare || window._phantom ||\n            window.__selenium_unwrapped || window.__webdriver_evaluate);\n    },\n\n    isHeadless() {\n        if (navigator.plugins.length === 0) return true;\n        if (navigator.languages.length === 0) return true;\n        if (navigator.webdriver) return true;\n        if (navigator.userAgent.includes('HeadlessChrome')) return true;\n        if (navigator.userAgent.includes('Chrome') && !window.chrome) return true;\n        return false;\n    },\n\n    // Storage checks\n    hasLocalStorage() {\n        try { localStorage.setItem('test', 'test'); localStorage.removeItem('test'); return true; } catch { return false; }\n    },\n    hasSessionStorage() {\n        try { sessionStorage.setItem('test', 'test'); sessionStorage.removeItem('test'); return true; } catch { return false; }\n    },\n    hasIndexedDB() {\n        return !!window.indexedDB;\n    },\n\n    // Hash function\n    hash(str) {\n        let hash = 0;\n        for (let i = 0; i < str.length; i++) {\n            hash = (hash << 5) - hash + str.charCodeAt(i);\n            hash = hash & hash;\n        }\n        return Math.abs(hash).toString(16);\n    },\n\n    // Generate fingerprint ID\n    async generateFingerprintID(data) {\n        const components = [\n            data.screen_width, data.screen_height, data.screen_color_depth,\n            data.device_pixel_ratio, data.hardware_concurrency, data.platform,\n            data.timezone, data.language, data.webgl_renderer, data.webgl_vendor,\n            data.canvas_hash, data.audio_hash, data.fonts_detected?.join(',')\n        ].join('|');\n        \n        return 'fp_' + this.hash(components);\n    },\n\n    // Calculate confidence\n    calculateConfidence(data) {\n        let score = 0;\n        if (data.canvas_hash) score += 15;\n        if (data.audio_hash) score += 15;\n        if (data.webgl_hash) score += 15;\n        if (data.webgl_renderer) score += 10;\n        if (data.fonts_detected?.length > 10) score += 15;\n        if (data.hardware_concurrency) score += 5;\n        if (data.device_memory) score += 5;\n        if (data.timezone) score += 5;\n        if (data.language) score += 5;\n        if (data.platform) score += 5;\n        if (data.screen_width) score += 5;\n        return Math.min(score, 100);\n    },\n\n    /**\n     * Detect IPv4 and IPv6 connectivity using tracking pixels\n     * ipv4.yourinfo.ai has only A records, ipv6.yourinfo.ai has only AAAA records\n     * Uses img tags to bypass mixed content restrictions (passive content)\n     * Server captures the TCP fingerprint and IP from these requests\n     */\n    async detectDualStackIPs(sessionId) {\n        const results = {\n            ipv4: null,\n            ipv6: null,\n            ipv4_reachable: false,\n            ipv6_reachable: false,\n            dual_stack: false\n        };\n\n        // Get IP from main domain - this tells us what IP version we're using\n        try {\n            const mainProbe = await this.probeIP('https://yourinfo.ai/m', 3000);\n            if (mainProbe && mainProbe.ip) {\n                if (mainProbe.ip.includes(':')) {\n                    results.ipv6 = mainProbe.ip;\n                    results.ipv6_reachable = true;\n                } else if (mainProbe.ip.includes('.')) {\n                    results.ipv4 = mainProbe.ip;\n                    results.ipv4_reachable = true;\n                }\n            }\n        } catch (e) {\n            console.log('Main domain probe failed:', e);\n        }\n\n        // Try to probe the OTHER IP version via subdomains\n        // Note: This requires wildcard SSL cert or separate certs for ipv4/ipv6 subdomains\n        try {\n            if (results.ipv6 && !results.ipv4) {\n                // We connected via IPv6, try to get IPv4\n                const v4Probe = await this.probeIP('https://ipv4.yourinfo.ai/m', 2000);\n                if (v4Probe && v4Probe.ip && v4Probe.ip.includes('.') && !v4Probe.ip.includes(':')) {\n                    results.ipv4 = v4Probe.ip;\n                    results.ipv4_reachable = true;\n                }\n            } else if (results.ipv4 && !results.ipv6) {\n                // We connected via IPv4, try to get IPv6\n                const v6Probe = await this.probeIP('https://ipv6.yourinfo.ai/m', 2000);\n                if (v6Probe && v6Probe.ip && v6Probe.ip.includes(':')) {\n                    results.ipv6 = v6Probe.ip;\n                    results.ipv6_reachable = true;\n                }\n            }\n        } catch (e) {\n            // Subdomain probes may fail due to SSL cert mismatch - that's okay\n            console.log('Subdomain probe failed (may need wildcard cert):', e.message || e);\n        }\n\n        // Dual-stack if we successfully got BOTH IPv4 and IPv6 addresses\n        results.dual_stack = !!(results.ipv4 && results.ipv6);\n\n        return results;\n    },\n    \n    /**\n     * Load a tracking pixel via img tag\n     * Returns true if the image loaded (connectivity exists)\n     */\n    probePixel: function(baseUrl, sessionId, stackType, timeout) {\n        return new Promise((resolve) => {\n            const img = new Image();\n            const timeoutId = setTimeout(() => {\n                img.onload = null;\n                img.onerror = null;\n                resolve(false);\n            }, timeout);\n            \n            img.onload = () => {\n                clearTimeout(timeoutId);\n                resolve(true);\n            };\n            \n            img.onerror = () => {\n                clearTimeout(timeoutId);\n                // Even on error, the TCP connection may have happened\n                // Mixed content will cause onerror but server still sees it\n                resolve(false);\n            };\n            \n            // Add cache buster and session info\n            const cacheBuster = Date.now() + Math.random();\n            img.src = `${baseUrl}/p?s=${sessionId}&t=${stackType}&_=${cacheBuster}`;\n        });\n    },\n\n    /**\n     * Probe an IP endpoint with timeout\n     */\n    probeIP: async function(url, timeout) {\n        const controller = new AbortController();\n        const timeoutId = setTimeout(() => controller.abort(), timeout);\n\n        try {\n            const response = await fetch(url, {\n                method: 'GET',\n                signal: controller.signal,\n                mode: 'cors'\n            });\n            clearTimeout(timeoutId);\n            \n            if (response.ok) {\n                return await response.json();\n            }\n            return null;\n        } catch (e) {\n            clearTimeout(timeoutId);\n            // Connection failed (no route, timeout, DNS failure)\n            return null;\n        }\n    },\n    \n    /**\n     * JSONP-based IP probe - bypasses mixed content restrictions\n     * Works by injecting a script tag that calls a global callback function\n     */\n    probeIPJsonp: async function(url, timeout) {\n        return new Promise((resolve) => {\n            const callbackName = '_ipProbe_' + Math.random().toString(36).substring(7);\n            const script = document.createElement('script');\n            \n            // Set up timeout\n            const timeoutId = setTimeout(() => {\n                cleanup();\n                resolve(null);\n            }, timeout);\n            \n            // Callback function that will be called by the JSONP response\n            window[callbackName] = (data) => {\n                cleanup();\n                resolve(data);\n            };\n            \n            const cleanup = () => {\n                clearTimeout(timeoutId);\n                delete window[callbackName];\n                if (script.parentNode) {\n                    script.parentNode.removeChild(script);\n                }\n            };\n            \n            // Handle script load errors\n            script.