          "content": {
            "size": 13778,
            "mimeType": "text/html; charset=utf-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>YourInfo.ai</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            background: #000;\n            color: #fff;\n            font-family: 'Courier New', Courier, monospace;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: flex-start;\n            padding: 40px 20px 100px 20px;\n            line-height: 1.6;\n        }\n        \n        .container {\n            max-width: 800px;\n            width: 100%;\n            text-align: left;\n        }\n        \n        /* Loading phase */\n        #loading-phase {\n            text-align: center;\n        }\n        \n        .loading-text {\n            font-size: 18px;\n            margin-bottom: 30px;\n            opacity: 0.8;\n        }\n        \n        .countdown {\n            font-size: 72px;\n            font-weight: bold;\n            margin-bottom: 20px;\n            font-family: 'Courier New', monospace;\n        }\n        \n        .status-text {\n            font-size: 14px;\n            opacity: 0.5;\n            margin-top: 20px;\n        }\n        \n        .blink {\n            animation: blink 1s infinite;\n        }\n        \n        @keyframes blink {\n            0%, 50% { opacity: 1; }\n            51%, 100% { opacity: 0; }\n        }\n        \n        /* Analysis phase */\n        #analysis-phase {\n            display: none;\n        }\n        \n        .analysis-output {\n            font-size: 18px;\n            line-height: 1.8;\n            white-space: pre-wrap;\n            word-wrap: break-word;\n        }\n        \n        .cursor {\n            display: inline-block;\n            width: 10px;\n            height: 20px;\n            background: #fff;\n            animation: cursor-blink 0.7s infinite;\n            vertical-align: middle;\n            margin-left: 2px;\n        }\n        \n        @keyframes cursor-blink {\n            0%, 50% { opacity: 1; }\n            51%, 100% { opacity: 0; }\n        }\n        \n        /* Typewriter effect */\n        .typewriter {\n            overflow: hidden;\n        }\n        \n        /* Footer */\n        .footer {\n            position: fixed;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            text-align: center;\n            font-size: 12px;\n            padding: 15px 20px;\n            background: linear-gradient(to top, rgba(0,0,0,1) 0%, rgba(0,0,0,0.95) 70%, rgba(0,0,0,0) 100%);\n            z-index: 100;\n        }\n        \n        .footer p {\n            margin-bottom: 6px;\n            color: #666;\n        }\n        \n        .footer a {\n            color: #4a9eff;\n            text-decoration: none;\n        }\n        \n        .footer a:hover {\n            color: #7bb8ff;\n            text-decoration: underline;\n        }\n        \n        /* Scrollbar */\n        ::-webkit-scrollbar {\n            width: 8px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #000;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: #333;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <!-- Loading Phase -->\n        <div id=\"loading-phase\">\n            <div class=\"loading-text\">RESEARCHING YOUR INFORMATION<span class=\"blink\">...</span></div>\n            <div class=\"countdown\" id=\"countdown\">25</div>\n            <div class=\"status-text\" id=\"status-text\">Initializing connection...</div>\n        </div>\n        \n        <!-- Analysis Phase -->\n        <div id=\"analysis-phase\">\n            <div class=\"analysis-output\" id=\"output\"></div>\n            <span class=\"cursor\" id=\"cursor\"></span>\n        </div>\n    </div>\n    \n    <div class=\"footer\">\n        <p>Concerned about your digital privacy?</p>\n        <a href=\"https://www.doxx.net\" target=\"_blank\" class=\"sponsor-link\">doxx.net - Secure networking for humans</a>\n    </div>\n    \n    <script src=\"/js/fingerprint.js\"></script>\n    <script>\n        (function() {\n            let ws = null;\n            let sessionId = null;\n            let countdownValue = 25;\n            let countdownInterval = null;\n            let analysisStarted = false;\n            let fingerprintData = null;\n            \n            const statusMessages = [\n                \"Initializing connection...\",\n                \"Analyzing network fingerprint...\",\n                \"Querying intelligence databases...\",\n                \"Cross-referencing behavioral patterns...\",\n                \"Profiling device characteristics...\",\n                \"Retrieving demographic data...\",\n                \"Analyzing browsing patterns...\",\n                \"Compiling psychological profile...\",\n                \"Correlating data sources...\",\n                \"Generating analysis...\"\n            ];\n            \n            function init() {\n                // Start countdown\n                startCountdown();\n                \n                // Collect fingerprint in background\n                collectFingerprint();\n                \n                // Connect WebSocket\n                connectWebSocket();\n            }\n            \n            function startCountdown() {\n                const countdownEl = document.getElementById('countdown');\n                const statusEl = document.getElementById('status-text');\n                let statusIndex = 0;\n                \n                countdownInterval = setInterval(() => {\n                    countdownValue--;\n                    countdownEl.textContent = countdownValue;\n                    \n                    // Update status message every 2-3 seconds\n                    if (countdownValue % 3 === 0 && statusIndex < statusMessages.length - 1) {\n                        statusIndex++;\n                        statusEl.textContent = statusMessages[statusIndex];\n                    }\n                    \n                    if (countdownValue <= 0) {\n                        clearInterval(countdownInterval);\n                        // If analysis hasn't started yet, wait for it\n                        if (!analysisStarted) {\n                            statusEl.textContent = \"Finalizing analysis...\";\n                            \n                            // Timeout after 15 more seconds - show error\n                            setTimeout(() => {\n                                if (!analysisStarted) {\n                                    showError(\"Analysis timed out. The AI service may be temporarily unavailable. Please refresh to try again.\");\n                                }\n                            }, 15000);\n                        }\n                    }\n                }, 1000);\n            }\n            \n            function showError(message) {\n                clearInterval(countdownInterval);\n                document.getElementById('loading-phase').innerHTML = `\n                    <div style=\"color: #ff6b6b; text-align: center;\">\n                        <div style=\"font-size: 48px; margin-bottom: 20px;\">⚠</div>\n                        <div style=\"font-size: 16px; margin-bottom: 20px;\">${message}</div>\n                        <button onclick=\"location.reload()\" style=\"\n                            background: #333;\n                            color: #fff;\n                            border: 1px solid #555;\n                            padding: 10px 30px;\n                            font-size: 14px;\n                            cursor: pointer;\n                            font-family: inherit;\n                        \">Try Again</button>\n                    </div>\n                `;\n            }\n            \n            async function collectFingerprint() {\n                try {\n                    // Add timeout to fingerprint collection (15 seconds max)\n                    const timeoutPromise = new Promise((_, reject) => \n                        setTimeout(() => reject(new Error('Fingerprint collection timeout')), 15000)\n                    );\n                    fingerprintData = await Promise.race([\n                        Fingerprint.collect(),\n                        timeoutPromise\n                    ]);\n                    console.log('Fingerprint collected');\n                } catch (e) {\n                    console.error('Fingerprint error:', e);\n                    // Send minimal fingerprint data so we can still analyze\n                    fingerprintData = { \n                        error: e.message || 'collection_failed',\n                        userAgent: navigator.userAgent,\n                        language: navigator.language,\n                        platform: navigator.platform,\n                        screenWidth: screen.width,\n                        screenHeight: screen.height\n                    };\n                }\n            }\n            \n            function connectWebSocket() {\n                const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';\n                ws = new WebSocket(`${protocol}//${window.location.host}/ws`);\n                \n                ws.onopen = () => {\n                    console.log('Connected');\n                };\n                \n                ws.onmessage = (event) => {\n                    const msg = JSON.parse(event.data);\n                    \n                    switch(msg.type) {\n                        case 'welcome':\n                            sessionId = msg.session_id;\n                            // Send fingerprint once we have session\n                            if (fingerprintData) {\n                                sendFingerprint();\n                            } else {\n                                // Wait for fingerprint with timeout\n                                let fpWaitTime = 0;\n                                const checkFp = setInterval(() => {\n                                    fpWaitTime += 100;\n                                    if (fingerprintData) {\n                                        clearInterval(checkFp);\n                                        sendFingerprint();\n                                    } else if (fpWaitTime >= 10000) {\n                                        // 10 second timeout - send minimal fingerprint\n                                        clearInterval(checkFp);\n                                        console.error('Fingerprint collection timed out, sending minimal data');\n                                        fingerprintData = { error: 'collection_timeout', userAgent: navigator.userAgent };\n                                        sendFingerprint();\n                                    }\n                                }, 100);\n                            }\n                            break;\n                            \n                        case 'profile_updated':\n                            // Request AI analysis with scary mode\n                            requestScaryAnalysis();\n                            break;\n                            \n                        case 'ai_stream':\n                            if (!analysisStarted) {\n                                startAnalysisPhase();\n                            }\n                            appendText(msg.content);\n                            break;\n                            \n                        case 'ai_done':\n                            document.getElementById('cursor').style.display = 'none';\n                            break;\n                            \n                        case 'ai_error':\n                            showError(\"AI analysis failed: \" + (msg.error || \"Unknown error\") + \". Please try again.\");\n                            break;\n                    }\n                };\n                \n                ws.onerror = (err) => {\n                    console.error('WebSocket error:', err);\n                    showError(\"Connection error. Please check your internet connection and try again.\");\n                };\n                \n                ws.onclose = (event) => {\n                    console.log('WebSocket closed:', event.code, event.reason);\n                    if (!analysisStarted && countdownValue <= 0) {\n                        showError(\"Connection closed unexpectedly. Please refresh to try again.\");\n                    }\n                };\n            }\n            \n            function sendFingerprint() {\n                if (ws && ws.readyState === WebSocket.OPEN && fingerprintData) {\n                    ws.send(JSON.stringify({\n                        type: 'fingerprint',\n                        payload: fingerprintData\n                    }));\n                }\n            }\n            \n            function requestScaryAnalysis() {\n                if (ws && ws.readyState === WebSocket.OPEN) {\n                    ws.send(JSON.stringify({\n                        type: 'analyze',\n                        payload: { reason: 'scary_mode' }\n                    }));\n                }\n            }\n            \n            function startAnalysisPhase() {\n                analysisStarted = true;\n                clearInterval(countdownInterval);\n                \n                document.getElementById('loading-phase').style.display = 'none';\n                document.getElementById('analysis-phase').style.display = 'block';\n            }\n            \n            function appendText(text) {\n                const output = document.getElementById('output');\n                output.textContent += text;\n                // NO auto-scroll - let user read at their own pace\n            }\n            \n            // Start\n            init();\n        })();\n    </script>\n</body>\n</html>\n"
          },
          "headersSize": 0,
          "bodySize": 13889,
          "redirectURL": "",
          "_transferSize": 13889
