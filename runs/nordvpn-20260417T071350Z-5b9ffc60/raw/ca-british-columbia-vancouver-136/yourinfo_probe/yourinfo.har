   }\n        }\n    },\n    \n    /**\n     * Mask sensitive data for display (but we still captured it)\n     */\n    maskSensitive(field, value) {\n        // Show that we got it, but partially mask for display\n        if (value.length <= 4) return value;\n        \n        if (field === 'email' && value.includes('@')) {\n            const [local, domain] = value.split('@');\n            return local.substring(0, 2) + '***@' + domain;\n        }\n        \n        if (field === 'phone' || field === 'tel') {\n            return value.substring(0, 3) + '-***-' + value.slice(-4);\n        }\n        \n        // Show first and last 2 chars\n        return value.substring(0, 2) + '•'.repeat(Math.min(value.length - 4, 8)) + value.slice(-2);\n    },\n    \n    /**\n     * Format field name for display\n     */\n    formatFieldName(field) {\n        const names = {\n            'email': 'Email Address',\n            'username': 'Username',\n            'name': 'Full Name',\n            'phone': 'Phone Number',\n            'organization': 'Company/Org',\n            'address': 'Street Address',\n            'city': 'City',\n            'zip': 'ZIP/Postal Code'\n        };\n        return names[field] || field;\n    },\n    \n    /**\n     * Add listener for captured data\n     */\n    onCapture(callback) {\n        this.listeners.push(callback);\n    },\n    \n    /**\n     * Notify listeners\n     */\n    notifyListeners() {\n        this.listeners.forEach(cb => cb(this.captured));\n    },\n    \n    /**\n     * Get all captured data\n     */\n    getCaptured() {\n        return { ...this.captured };\n    }\n};\n\n// Initialize when DOM is ready\nif (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', () => AutofillProbe.init());\n} else {\n    AutofillProbe.init();\n}\n\nwindow.AutofillProbe = AutofillProbe;\n"
