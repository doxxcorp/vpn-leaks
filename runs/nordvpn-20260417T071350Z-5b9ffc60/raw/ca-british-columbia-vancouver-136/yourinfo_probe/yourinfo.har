re-filled values\n        setTimeout(() => this.probeAllFields(), 500);\n        \n        // Update status\n        if (messageEl) {\n            messageEl.textContent = 'Waiting for form interaction...';\n        }\n    },\n    \n    /**\n     * Check if a field was autofilled\n     */\n    checkForAutofill(input) {\n        // Method 1: Check computed styles for autofill\n        const styles = window.getComputedStyle(input);\n        const bgImage = styles.getPropertyValue('background-image');\n        \n        // Chrome adds a special background when autofilling\n        if (bgImage && bgImage !== 'none') {\n            this.onAutofillDetected(input);\n        }\n        \n        // Method 2: Check if value exists but we didn't see an input event\n        if (input.value && !this.captured[input.name]) {\n            this.captureValue(input, 'autofill-detected');\n        }\n    },\n    \n    /**\n     * Handle input events\n     */\n    onInput(e) {\n        const input = e.target;\n        const source = e.isTrusted ? 'user-input' : 'programmatic';\n        \n        // Check if this looks like autofill (multiple chars at once)\n        if (input.value.length > 3 && source === 'user-input') {\n            // Could be paste or autofill\n            this.captureValue(input, 'input-event');\n        }\n    },\n    \n    /**\n     * Called when autofill is detected via CSS\n     */\n    onAutofillDetected(input) {\n        setTimeout(() => {\n            if (input.value) {\n                this.captureValue(input, 'css-autofill');\n            }\n        }, 50);\n    },\n    \n    /**\n     * Capture a field value\n     */\n    captureValue(input, method) {\n        const fieldName = input.name || input.id;\n        const value = input.value;\n        \n        if (!value || this.captured[fieldName] === value) return;\n        \n        this.captured[fieldName] = value;\n        \n        console.log(`[Autofill] Captured ${fieldName}: ${value} (via ${method})`);