tify-center size-12 bg-accent-subtle rounded-sm'>\n            <svg class='size-5 text-accent'>\n              \n              \n              \n              \n              \n              <use href='#Nord'></use>\n              \n            </svg>\n          </span>\n          <span class='flex-1 line-clamp-2'>\n            Explore other Nord Security products\n          </span>\n          <span>\n            <svg class='size-5'>\n              <use href='#ChevronRight'></use>\n            </svg>\n          </span>\n        </a>\n        \n      </div>\n    </div>\n  </div>\n</section>\n\n<section class='bg-primary py-10' data-section='AppReleases'>\n  <div class='mx-auto max-w-6xl px-4'>\n    <div class='Home-page__section--releases container mx-auto'>\n      <div class='grid grid-cols-1 sm:grid-cols-2 gap-8'>\n\n        <div class='text-center flex align-center justify-center'>\n          <img src='https://sb.nordcdn.com/m/83d4a4bd1d9eb5e5/original/woman-box-nord-vpn-md-svg.svg'\n            alt='Women with box' width='300' height='300' />\n        </div>\n        <div class='flex flex-col justify-center gap-6'>\n          <h2 class='text-primary heading-xl'>Find out what’s new in NordVPN</h2>\n          <p class='body-md'>The NordVPN app is regularly updated to ensure that our users always have the latest features and the highest level of security. Find out about the latest improvements and enhancements we’ve made to our services.</p>\n          <a href='https://nordvpn.com/blog/category/service-updates/app-updates/' data-appearance='fill' data-variant='accent' data-size='md'\n            aria-label='View Updates' data-ga-slug='View Updates' role='button' class='w-full sm:w-fit'>View Updates</a>\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class='py-16' data-section='QuickHelp'>\n  <div class='mx-auto max-w-6xl px-4'>\n    <div class='mx-auto flex justify-center align-center h-full flex-col'>\n      <h2 class='text-primary tex