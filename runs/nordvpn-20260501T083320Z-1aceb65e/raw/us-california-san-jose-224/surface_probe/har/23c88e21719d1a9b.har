            "text": "<!DOCTYPE html>\n<html dir=\"ltr\" lang=\"en-US\">\n<head>\n  <meta charset=\"utf-8\" />\n  <!-- v27301 -->\n\n\n  <title>Live Chat, VPN Setup, Troubleshooting | NordVPN Customer Support</title>\n\n  \n\n  <link rel=\"canonical\" href=\"https://support.nordvpn.com/hc/en-us\">\n<link rel=\"alternate\" hreflang=\"da\" href=\"https://support.nordvpn.com/hc/da\">\n<link rel=\"alternate\" hreflang=\"de\" href=\"https://support.nordvpn.com/hc/de\">\n<link rel=\"alternate\" hreflang=\"en-us\" href=\"https://support.nordvpn.com/hc/en-us\">\n<link rel=\"alternate\" hreflang=\"es\" href=\"https://support.nordvpn.com/hc/es\">\n<link rel=\"alternate\" hreflang=\"fr\" href=\"https://support.nordvpn.com/hc/fr\">\n<link rel=\"alternate\" hreflang=\"it\" href=\"https://support.nordvpn.com/hc/it\">\n<link rel=\"alternate\" hreflang=\"ja\" href=\"https://support.nordvpn.com/hc/ja\">\n<link rel=\"alternate\" hreflang=\"ko\" href=\"https://support.nordvpn.com/hc/ko\">\n<link rel=\"alternate\" hreflang=\"nl\" href=\"https://support.nordvpn.com/hc/nl\">\n<link rel=\"alternate\" hreflang=\"no\" href=\"https://support.nordvpn.com/hc/no\">\n<link rel=\"alternate\" hreflang=\"pl\" href=\"https://support.nordvpn.com/hc/pl\">\n<link rel=\"alternate\" hreflang=\"pt-br\" href=\"https://support.nordvpn.com/hc/pt-br\">\n<link rel=\"alternate\" hreflang=\"sv\" href=\"https://support.nordvpn.com/hc/sv\">\n<link rel=\"alternate\" hreflang=\"x-default\" href=\"https://support.nordvpn.com/hc/en-us\">\n<link rel=\"alternate\" hreflang=\"zh-tw\" href=\"https://support.nordvpn.com/hc/zh-tw\">\n\n  <link rel=\"stylesheet\" href=\"//static.zdassets.com/hc/assets/application-4f03043d3b7bad43ce9a304b007cb1a7.css\" media=\"all\" id=\"stylesheet\" />\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"/hc/theming_assets/757086/445532/style.css?digest=45872676122001\">\n\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"//static.zdassets.com/hc/assets/favicon.ico\">\n\n    \n\n  \n      <m